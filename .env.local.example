# ── Database (Neon Postgres) ───────────────────────────────────
# Get this from: https://neon.tech → New Project → Connection String
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Auth.js v5 ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"

# ── App URL ───────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: your Vercel URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google OAuth (Auth.js v5 — add in Google Cloud Console) ───
# Callback URL (add both in Google Cloud → APIs & Services → Credentials):
#   Local:      http://localhost:3000/api/auth/callback/google
#   Production: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── Optional: First admin setup ───────────────────────────────
# After running db:push, use Prisma Studio or a seed script
# to set role = "ADMIN" on your account
