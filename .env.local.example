# ── Database (Neon Postgres) ───────────────────────────────────
# Get this from: https://neon.tech → New Project → Connection String
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Auth.js v5 ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"

# AUTH_URL: used by Auth.js to construct OAuth callback URLs.
# Must match the Vercel deployment URL exactly (no trailing slash).
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
AUTH_URL="http://localhost:3000"

# ── App URL ───────────────────────────────────────────────────
# Used by email templates, unsubscribe links, share links.
# Must be set to the main production domain in Vercel env vars.
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google OAuth ──────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs to add:
#   Local:      http://localhost:3000/api/auth/callback/google
#   Production: https://yourdomain.com/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── Microsoft Graph (transactional email) ─────────────────────
# Used for: welcome, password reset, security alerts, account alerts
# Azure Portal → App registrations → your app → Certificates & secrets
AZURE_CLIENT_ID="your-azure-client-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"
AZURE_TENANT_ID="your-azure-tenant-id"
GRAPH_EMAIL_SENDER="noreply@yourdomain.com"

# ── Azure Communication Services (bulk email) ─────────────────
# Used for: campaigns, outreach, new release/episode, notify-me follow-ups
# Azure Portal → Communication Services → your resource → Keys
ACS_CONNECTION_STRING="endpoint=https://your-acs.communication.azure.com/;accesskey=your-key"
ACS_SENDER_ADDRESS="DoNotReply@your-acs-domain.azurecomm.net"

# ── SMTP (optional fallback) ──────────────────────────────────
# Only used if bulk provider is set to SMTP in admin settings
SMTP_HOST="smtp.yourmailprovider.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"

# ── Seed script (dev only) ────────────────────────────────────
# Used by: npm run db:seed — creates the first admin user
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="change-me-before-running"

# ── Cloudflare Turnstile (public subscription form) ───────────
# Cloudflare Dashboard → Turnstile → Add Site
# NEXT_PUBLIC_TURNSTILE_SITE_KEY: safe for browser (public)
# TURNSTILE_SECRET_KEY: server-only — NEVER expose to client code
# If TURNSTILE_SECRET_KEY is not set, the /api/subscribe route returns 503
# and saves nothing (fail-closed behavior).
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# ── Cloudflare R2 (admin media uploads) ──────────────────────
# Used for: direct admin uploads of project media (images, videos, trailers)
# Cloudflare Dashboard → R2 → API Tokens → Create Token
# Token needs: Admin permission for bucket
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_BASE_URL="https://your-r2-public-url.r2.dev"
# R2_PUBLIC_URL is accepted as a fallback if R2_PUBLIC_BASE_URL is not set

# ── Worker secret (background video processing worker) ────────
# Shared secret between this app and the external HLS transcoding worker.
# Generate with: openssl rand -hex 32
# Must match the WORKER_SECRET env var set on the worker process.
# Keep this value private — never expose it to the browser.
WORKER_SECRET=
