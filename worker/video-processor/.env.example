# URL of the deployed Next.js app (no trailing slash)
# Use https://impactaistudio.com for production
# Use the Vercel preview URL for testing
APP_BASE_URL=https://impactaistudio.com

# Shared secret — must match WORKER_SHARED_SECRET (or WORKER_SECRET) in the app's environment
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
WORKER_SHARED_SECRET=

# Port for the daemon's local HTTP server (health check + manual trigger)
# Only used by "npm run serve" — not needed for "process-once"
WORKER_PORT=4242

# Cloudflare R2 — same values as the Next.js app
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# Google Gemini — used for subtitle TRANSLATION (always) and transcription fallback
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Model for translation and Gemini transcription fallback
GEMINI_MODEL=gemini-2.5-flash

# ── Transcription provider ────────────────────────────────────────────────────
# Auto-detection (recommended):
#   Set TRANSCRIPTION_ENDPOINT → whisper is used automatically
#   Leave it blank → Gemini is used as fallback
#
# Explicit override (optional):
#   TRANSCRIPTION_PROVIDER=whisper   — force whisper even without endpoint (will error)
#   TRANSCRIPTION_PROVIDER=gemini    — force Gemini even if endpoint is set
#
# Whisper request:  POST /transcribe  { url, language, mediaType, workId }
# Whisper response: { segments: [{ start, end, text }] }
#
# Use ngrok for local dev, a deployed faster-whisper service for production.
TRANSCRIPTION_ENDPOINT=
TRANSCRIPTION_SECRET=

# Optional: retry with Gemini if whisper endpoint fails (set to "gemini" to enable)
TRANSCRIPTION_FALLBACK_PROVIDER=
