# URL of the deployed Next.js app (no trailing slash)
# Use https://impactaistudio.com for production
# Use the Vercel preview URL for testing
APP_BASE_URL=https://impactaistudio.com

# Shared secret — must match WORKER_SECRET in the app's environment
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
WORKER_SECRET=

# Port for the daemon's local HTTP server (health check + manual trigger)
# Only used by "npm run serve" — not needed for "process-once"
WORKER_PORT=4242

# Cloudflare R2 — same values as the Next.js app
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
