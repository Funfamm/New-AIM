// AIM Studio Lite — Prisma Schema
// Run: npx prisma db push  (after setting DATABASE_URL in .env)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum WorkType {
  SHORT_FILM
  FULL_FILM
  SERIES
  EPISODE
  TRAILER
  COMMERCIAL
  BRANDING
  CAMPAIGN
  CASE_STUDY
}

enum WorkStatus {
  DRAFT
  PUBLISHED
  PRIVATE
}

enum NotificationType {
  NEW_RELEASE
  ACCOUNT
  SYSTEM
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          Role      @default(USER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  progress      WatchProgress[]
  accounts      Account[]
  sessions      Session[]
  savedWorks    SavedWork[]
  preferences   UserPreferences?
  notifications Notification[]

  @@map("users")
}

// ─────────────────────────────────────────────
// WORK  (replaces Film — covers all content types)
// ─────────────────────────────────────────────

model Work {
  id          String     @id @default(cuid())
  slug        String     @unique
  type        WorkType
  status      WorkStatus @default(DRAFT)
  title       String
  description String?
  posterUrl   String?

  // Video URLs — stored only, files live in R2/S3 later
  trailerUrl  String?   // short film, full film, series
  videoUrl    String?   // main video (film, episode, commercial, branding)
  teaserUrl   String?   // optional second video for commercials

  // Film/series metadata
  year        Int?
  duration    Int?      // minutes
  director    String?
  genre       String?

  // Client/portfolio metadata
  clientName  String?
  industry    String?
  projectGoal String?
  deliverables String?
  caseStudy   String?
  galleryUrls String[]  @default([])

  // Display controls
  requiresAuth Boolean  @default(false)
  featured     Boolean  @default(false)
  showOnHome   Boolean  @default(false)
  order        Int      @default(0)

  // Series → Episode relationship (self-referential)
  parentId      String?
  parent        Work?   @relation("WorkEpisodes", fields: [parentId], references: [id], onDelete: SetNull)
  episodes      Work[]  @relation("WorkEpisodes")
  episodeNumber Int?
  seasonNumber  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress      WatchProgress[]
  savedBy       SavedWork[]
  notifications Notification[]

  @@map("works")
}

// ─────────────────────────────────────────────
// WATCH PROGRESS
// ─────────────────────────────────────────────

model WatchProgress {
  id        String   @id @default(cuid())
  userId    String
  workId    String
  seconds   Int      @default(0)
  duration  Int?     // duration in minutes at time of save — used to compute % complete
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@map("watch_progress")
}

// ─────────────────────────────────────────────
// AUTH.JS ADAPTER MODELS
// ─────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// PASSWORD RESET
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique  // SHA-256 of the raw token — raw token never stored
  email     String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// WATCHLIST
// ─────────────────────────────────────────────

model SavedWork {
  id        String   @id @default(cuid())
  userId    String
  workId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@map("saved_works")
}

// ─────────────────────────────────────────────
// USER PREFERENCES
// ─────────────────────────────────────────────

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Notification preferences
  emailNewReleases   Boolean @default(true)
  emailAccountAlerts Boolean @default(true)

  // Playback preferences
  autoplay       Boolean @default(true)
  defaultQuality String  @default("auto") // "auto" | "1080p" | "720p" | "480p"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  workId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work? @relation(fields: [workId], references: [id], onDelete: SetNull)

  @@map("notifications")
}
